# ── Server ──
PORT=5000
NODE_ENV=development

# ── MongoDB ──
# Local:   mongodb://localhost:27017/hisaab
# Atlas:   mongodb+srv://<user>:<pass>@cluster.mongodb.net/hisaab
MONGO_URI=mongodb://localhost:27017/hisaab

# ── JWT ──
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_this_to_a_long_random_string_min_32_chars
JWT_EXPIRES_IN=7d

# ── OTP ──
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=5

# ── CORS ──
# Comma-separated list of allowed origins
# e.g. https://hisaab.vercel.app,http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:5500
